# Sikizana environment variables

# Google Gemini
GEMINI_API_KEY=

# Vara Network
VARA_PRIVATE_KEY=
VARA_NODE_URL=

# IPFS (Pinata)
PINATA_API_KEY=
PINATA_API_SECRET=

# Safaricom Daraja (M-Pesa STK Push)
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=https://your-domain.com/api/payments/callback

# Premium pricing
PREMIUM_RESOLUTION_KES=100

# Payment DB path
PAYMENT_DB_PATH=data/payments.db

# Xero OAuth 2.0 (Connect Your Xero flow)
# Create an app at https://developer.xero.com/myapps
# Select "Auth Code with PKCE" or "Auth Code (with client secret)"
# Set the redirect URI to: https://your-domain.com/api/xero/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://sikizana.persidian.com/api/xero/callback

# Stripe (monetization — subscription billing)
# Create account at https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
