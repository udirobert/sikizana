# Sikizana — AI Finance Assistant for Xero
# Environment variables

# LLM provider (NVIDIA NIM / OpenAI-compatible)
NVIDIA_BASE_URL=
NVIDIA_API_KEY=
LLM_MODEL=

# Google Gemini (vision — receipt matching)
GEMINI_API_KEY=

# Xero OAuth 2.0 (Connect Your Xero flow)
# Create an app at https://developer.xero.com/myapps
# Select "Auth Code with PKCE" or "Auth Code (with client secret)"
# Set the redirect URI to: https://your-domain.com/api/xero/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://sikizana.persidian.com/api/xero/callback

# Xero webhook signing key (optional — for webhook verification)
XERO_WEBHOOK_KEY=

# SQLite DB path (feedback, impact metrics)
PAYMENT_DB_PATH=data/sikizana.db

# CORS — comma-separated origins, or * for all
ALLOWED_ORIGINS=*

# Server port
PORT=8080

# Stripe (monetization — subscription billing)
# Create account at https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
