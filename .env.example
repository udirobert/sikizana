# Sikizana — AI Finance Assistant
# Environment variables

# LLM provider (NVIDIA NIM / OpenAI-compatible) — primary
NVIDIA_BASE_URL=
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_FALLBACK_MODEL=qwen/qwen3-next-80b-a3b-instruct
LLM_MODEL=

# Venice AI — cross-provider fallback when NVIDIA is unreachable.
# OpenAI-compatible API; same tool-calling loop works unchanged.
# If NVIDIA times out or errors, the agent automatically switches to Venice.
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b

# Exa AI — live web search for contextual HMRC/tax content while Siki works.
# Optional: without it, curated fallback content is shown instead.
EXA_API_KEY=

# Firecrawl — deep page scraping for detailed HMRC guidance extraction.
# Optional: enhances the context search with full-page content from gov.uk.
FIRECRAWL_API_KEY=

# Google Gemini (vision — receipt matching)
GEMINI_API_KEY=

# Xero OAuth 2.0 (Connect Your Xero flow)
# Create an app at https://developer.xero.com/myapps
# Select "Auth Code with PKCE" or "Auth Code (with client secret)"
# Set the redirect URI to: https://your-domain.com/api/xero/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://sikizana.persidian.com/api/xero/callback

# Xero webhook signing key (required for webhooks — Xero's intent-to-receive
# validation fails without HMAC verification)
XERO_WEBHOOK_KEY=

# SQLite DB path (Xero tokens, feedback, impact metrics, webhook events)
PAYMENT_DB_PATH=data/sikizana.db

# AP Integrity release controls. Empty AP_INTEGRITY_USER_IDS enables AP
# Integrity for every user; set authenticated design-partner IDs for a
# controlled cohort before launch.
# AP_INTEGRITY_DISABLED=true stops new AP scans globally without deleting
# prior review outcomes.
AP_INTEGRITY_USER_IDS=
AP_INTEGRITY_DISABLED=false

# CORS — comma-separated origins. "*" disables cookies (browsers reject
# wildcard + credentials), so set the real origin in production, e.g.
# ALLOWED_ORIGINS=https://sikizana.persidian.com
ALLOWED_ORIGINS=*

# Set true when serving over HTTPS so the session cookie is Secure
COOKIE_SECURE=false

# Server port
PORT=8080

# Stripe (monetization — subscription billing)
# Create account at https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# Billing enforcement: when true (and Stripe is configured), free-tier
# query limits and Pro-plan gates actually block. Leave false for open
# demos — usage is still metered either way.
BILLING_ENFORCED=false
FREE_TIER_MONTHLY_QUERIES=5

# Base URL used in Stripe checkout redirect URLs
APP_BASE_URL=https://sikizana.persidian.com

# Fernet key for encrypting Xero tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, a key is generated and persisted next to the database.
TOKEN_ENCRYPTION_KEY=

# SMTP for the weekly digest email, password reset, and email verification
# (optional — all are skipped if unset, but users can't reset passwords or
# verify their email without SMTP configured).
# Run digest weekly via cron: python -m src.jobs.send_digests
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# URLs used in password reset and email verification links.
# These should point to your frontend pages.
PASSWORD_RESET_URL=https://sikizana.persidian.com/reset-password
EMAIL_VERIFY_URL=https://sikizana.persidian.com/verify-email

# UK Corporation Tax rates (set by HMRC, not Xero). Configurable so they
# can be updated without a code change when the government changes rates.
CORP_TAX_SMALL_RATE=0.19
CORP_TAX_MAIN_RATE=0.25
CORP_TAX_SMALL_LIMIT=50000
CORP_TAX_MAIN_LIMIT=250000
CORP_TAX_MARGINAL_RELIEF=0.015

# Bank of England base rate for late payment interest (LPCD Act 1998).
# Statutory rate = 8% + Bank Rate.
BANK_RATE=5.25

# Supermemory Local — optional. When set, the agent gains persistent memory
# across sessions (recalls past findings, customer patterns, preferences)
# and semantic RAG over HMRC rules. When unset or unreachable, the app
# works identically — just without memory.
#
# Install:  curl -fsSL https://supermemory.ai/install | bash
# Run:      supermemory-server  (prints API key on first boot)
SUPERMEMORY_URL=http://localhost:6767
SUPERMEMORY_API_KEY=
