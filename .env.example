# Sikizana — AI Finance Assistant for Xero
# Environment variables

# LLM provider (NVIDIA NIM / OpenAI-compatible)
NVIDIA_BASE_URL=
NVIDIA_API_KEY=
LLM_MODEL=

# Google Gemini (vision — receipt matching)
GEMINI_API_KEY=

# Xero OAuth 2.0 (Connect Your Xero flow)
# Create an app at https://developer.xero.com/myapps
# Select "Auth Code with PKCE" or "Auth Code (with client secret)"
# Set the redirect URI to: https://your-domain.com/api/xero/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://sikizana.persidian.com/api/xero/callback

# Xero webhook signing key (required for webhooks — Xero's intent-to-receive
# validation fails without HMAC verification)
XERO_WEBHOOK_KEY=

# SQLite DB path (Xero tokens, feedback, impact metrics, webhook events)
PAYMENT_DB_PATH=data/sikizana.db

# CORS — comma-separated origins. "*" disables cookies (browsers reject
# wildcard + credentials), so set the real origin in production, e.g.
# ALLOWED_ORIGINS=https://sikizana.persidian.com
ALLOWED_ORIGINS=*

# Set true when serving over HTTPS so the session cookie is Secure
COOKIE_SECURE=false

# Server port
PORT=8080

# Stripe (monetization — subscription billing)
# Create account at https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# Billing enforcement: when true (and Stripe is configured), free-tier
# query limits and Pro-plan gates actually block. Leave false for open
# demos — usage is still metered either way.
BILLING_ENFORCED=false
FREE_TIER_MONTHLY_QUERIES=5

# Base URL used in Stripe checkout redirect URLs
APP_BASE_URL=https://sikizana.persidian.com

# Fernet key for encrypting Xero tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, a key is generated and persisted next to the database.
TOKEN_ENCRYPTION_KEY=
